# --- Reclaim Protocol credentials ---
# Obtained from https://dev.reclaimprotocol.org → create an app, then enable zkFetch
# in the app's Integration tab (CRITICAL: without enabling zkFetch, the API returns 401).
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=

# --- On-chain ---
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# Live ReclaimWeatherSource v2, redeployed 2026-05-17 after the IReclaim interface
# fix (PR #79). The v1 contract at 0x6Bf18DF23078f96d7FC035488e8C6fc68A4a502f is
# orphaned — its `if (!VERIFIER.verifyProof(...)) revert InvalidProof()` triggered
# unconditionally because the deployed Reclaim verifier returns false on success
# (missing `return true;` upstream). See docs/POC-NOTES.md §1.9 + §2.5.
RECLAIM_WEATHER_SOURCE_ADDRESS=0x23eF9B17002944941712770b292B6094C97BAe76

# Keeper signer (testnet only, fund via https://www.alchemy.com/faucets/arbitrum-sepolia)
# Use a dedicated address — NOT your admin EOA. The keeper has no special privileges
# on the contract; anyone with a valid Reclaim proof can submit. The private key in
# .env is acceptable for testnet POC; mainnet must use HSM / multisig / KMS.
KEEPER_PRIVATE_KEY=

# --- NWS target ---
NWS_STATION_ID=KJFK
NWS_BASE_URL=https://api.weather.gov

# --- Cadence ---
POLL_INTERVAL_SECONDS=600
